{
  "name": "dolphin-browser",
  "version": "2.0.0",
  "description": "Hizli ve guvenli Chromium tabanli Dolphin Browser v2.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.dolphin.browser",
    "productName": "Dolphin Browser",
    "icon": "icon.png",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "Agony270313",
      "repo": "dolphin-browser"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
